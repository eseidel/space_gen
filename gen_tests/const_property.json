{
    "openapi": "3.1.0",
    "info": {
        "title": "Const Property",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://example.com/const"
        }
    ],
    "paths": {
        "/list": {
            "get": {
                "operationId": "getList",
                "summary": "List",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ListResp"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/marker": {
            "get": {
                "operationId": "getMarker",
                "summary": "Marker",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Marker"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/rule": {
            "get": {
                "operationId": "getRule",
                "summary": "Rule",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Rule"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ListResp": {
                "type": "object",
                "description": "A single legal value renders differently by presence. A *required* marker fixed to a lone scalar `const` (`object`) is always present, so it collapses to a fixed getter returning the literal — no single-value enum type or file (issue #240). An *optional* one (`apiVersion`, `revision`) is 'absent, or that value', so it stays an omittable plain-scalar field; the constant is surfaced as a `static const` (e.g. `apiVersionValue`) for callers who want to set it explicitly.",
                "required": ["object", "count"],
                "properties": {
                    "object": {
                        "type": "string",
                        "const": "list",
                        "description": "Required marker fixed to the literal 'list'."
                    },
                    "apiVersion": {
                        "type": "string",
                        "const": "2024-01-01"
                    },
                    "revision": {
                        "type": "integer",
                        "const": 5
                    },
                    "count": {
                        "type": "integer"
                    }
                }
            },
            "Marker": {
                "type": "object",
                "description": "An object whose every property is a required lone const — the constructor takes no arguments and it stores nothing.",
                "required": ["kind"],
                "properties": {
                    "kind": {
                        "type": "string",
                        "const": "marker"
                    }
                }
            },
            "Rule": {
                "type": "object",
                "description": "The single-value `enum: [X]` spelling of a fixed value (how github tags its discriminated-union variants). A *required* one (`type`) collapses to a fixed getter, dropping the throwaway single-value enum type (issue #239); an *optional* one (`workflows`) stays an omittable plain-scalar field with the value surfaced as a `static const` (`workflowsValue`).",
                "required": ["type"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["creation"],
                        "description": "Required tag fixed to the one member 'creation'."
                    },
                    "workflows": {
                        "type": "string",
                        "enum": ["write"]
                    }
                }
            }
        }
    }
}
