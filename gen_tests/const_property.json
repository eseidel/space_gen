{
    "openapi": "3.1.0",
    "info": {
        "title": "Const Property",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://example.com/const"
        }
    ],
    "paths": {
        "/list": {
            "get": {
                "operationId": "getList",
                "summary": "List",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ListResp"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/marker": {
            "get": {
                "operationId": "getMarker",
                "summary": "Marker",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Marker"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/rule": {
            "get": {
                "operationId": "getRule",
                "summary": "Rule",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Rule"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "ListResp": {
                "type": "object",
                "description": "A paginated list response.",
                "required": ["object", "count"],
                "properties": {
                    "object": {
                        "type": "string",
                        "const": "list",
                        "description": "The type of this object."
                    },
                    "apiVersion": {
                        "type": "string",
                        "const": "2024-01-01",
                        "description": "The API version this response was produced with."
                    },
                    "revision": {
                        "type": "integer",
                        "const": 5
                    },
                    "count": {
                        "type": "integer"
                    }
                }
            },
            "Marker": {
                "type": "object",
                "description": "An empty marker object.",
                "required": ["kind"],
                "properties": {
                    "kind": {
                        "type": "string",
                        "const": "marker"
                    }
                }
            },
            "Rule": {
                "type": "object",
                "description": "A repository rule.",
                "required": ["type"],
                "properties": {
                    "type": {
                        "type": "string",
                        "enum": ["creation"],
                        "description": "The rule type."
                    },
                    "workflows": {
                        "type": "string",
                        "enum": ["write"]
                    }
                }
            }
        }
    }
