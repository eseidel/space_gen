{
    "openapi": "3.1.0",
    "info": {
        "title": "Types",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://example.com/types"
        }
    ],
    "paths": {
        "/types": {
            "get": {
                "summary": "Get types",
                "responses": {
                    "200": {
                        "description": "OK",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "date": {
                                            "$ref": "#/components/schemas/DateType"
                                        },
                                        "inlineDate": {
                                            "type": "string",
                                            "format": "date"
                                        },
                                        "email": {
                                            "$ref": "#/components/schemas/EmailType"
                                        },
                                        "uuid": {
                                            "$ref": "#/components/schemas/UuidType"
                                        },
                                        "timestamp": {
                                            "$ref": "#/components/schemas/Timestamp"
                                        },
                                        "widget": {
                                            "$ref": "#/components/schemas/Widget"
                                        },
                                        "status": {
                                            "$ref": "#/components/schemas/Status"
                                        },
                                        "stock": {
                                            "$ref": "#/components/schemas/StockStatus"
                                        },
                                        "priority": {
                                            "$ref": "#/components/schemas/Priority"
                                        }
                                    },
                                    "required": [
                                        "date",
                                        "inlineDate",
                                        "email",
                                        "uuid",
                                        "timestamp",
                                        "widget",
                                        "status"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "DateType": {
                "type": "string",
                "format": "date"
            },
            "EmailType": {
                "type": "string",
                "format": "email"
            },
            "UuidType": {
                "type": "string",
                "format": "uuid"
            },
            "Timestamp": {
                "type": "string",
                "format": "date-time"
            },
            "Status": {
                "type": "string",
                "enum": ["active", "inactive", "pending"]
            },
            "StockStatus": {
                "type": "string",
                "description": "Values whose sanitized identifiers collide — `in stock` and `in-stock` both reduce to the same identifier. The generated enum must disambiguate rather than declare it twice.",
                "enum": ["in stock", "in-stock", "out of stock"]
            },
            "Priority": {
                "type": "integer",
                "description": "An integer enum — a closed set of int values. Renders as a validated int newtype (not a Dart enum); the generated round-trip test also exercises the membership check throwing FormatException on an out-of-set value.",
                "enum": [1, 2, 3]
            },
            "Widget": {
                "type": "object",
                "description": "Smoke-test object to exercise list/map fields through the generated round-trip test — catches hashCode-vs-== drift on collections.",
                "required": ["id", "tags", "attributes"],
                "properties": {
                    "id": { "type": "integer", "format": "int64" },
                    "tags": {
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "attributes": {
                        "type": "object",
                        "additionalProperties": { "type": "string" }
                    }
                }
            }
        }
    }
}